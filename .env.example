ZETI_ALB_URL=http://ZETI-alb-133662152.ap-northeast-2.elb.amazonaws.com
LEAKED_KEY_PATH=./leaked-key/pkcs8_private_key.pem
KID=alias/jwt-signing-key-external

# Target 범위 — 접근 가능한 사용자 id 범위 (Phase 1 시뮬레이터 시작 sub부터)
VICTIM_SUB_START=140000002
VICTIM_SUB_END=140000500

# 공격할 사용자 수 — 위 범위 안에서 실제로 공격할 사용자 수.
#   순차 공격(S4/S5)  : VICTIM_SUB_START부터 이만큼 순차로
#   랜덤 공격(S5b/S6) : [START, END) 범위에서 이만큼 랜덤 비복원 추출
#   세 시나리오 모두 각 사용자 1회 방문. 비우면 범위 전체(END-START).
#   S2(토큰 하이재킹)는 단일 사용자 공격이라 이 값과 무관.
VICTIM_COUNT=100

# 공격 IP 라벨 (시뮬레이터가 ASN 매핑에 사용)
ATTACK_SOURCE_LABEL=external_vps   # cgnat_kr / enterprise / external_vps

# ─── XFF 위조용 source IP ──────────────────────────────────────────────
#   ALB append + Nginx의 log_format에 $http_x_forwarded_for 추가 + 백엔드
#   proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; 조합에서
#   ES 로그의 x_forwarded_for 필드(첫 토큰)에 박힌다.
#
#   시나리오별 IP 색깔 (실전 ASN 기반, prefix만 봐도 시나리오 구분):
#     222.x → S2 victim   (KT Corporation, AS4766 — 집 KT 인터넷)
#     73.x  → S2 attacker (US Residential — 탈취 토큰 해외 사용, Impossible Travel)
#     15.x  → S4          (AWS Asia Pacific Seoul, AS16509 — 클라우드 인스턴스)
#     98.x  → S6          (US Residential — 해외 가정용, Impossible Travel)
#     S5 풀 : 203.0.113 / 198.51.100 / 192.0.2 / 45.32.x  (Mixed Hosting / VPS)
#             옥텟 100~254 영역만 사용 — 단일 IP 시나리오(옥텟 1~99)와 충돌 0
# ────────────────────────────────────────────────────────────────────────

# S4 — 단일 IP 즉시 enumeration
S4_SOURCE_IP=15.164.10.40           # AWS Seoul (Hosting) — 단일 클라우드 인스턴스 enumeration

# S6 — Slow & Low + Impossible Travel
S6_SOURCE_IP=98.138.10.66           # US Residential (Comcast 류) — 해외 가정용, 한국 사용자 풀과 지리적 이상

# S2 — 토큰 하이재킹: victim(KR) → attacker(해외) — token_replay ip_country/ip_class 교차 시연
#   ★ attacker 는 반드시 비-한국(non-KR) IP 여야 한다. 한국 통신사 IP 를 쓰면
#   victim 과 같은 ip_class(cgnat_kr)·국가(KR)라 token_replay 가 0 점 → S2 미탐지.
#   (구 101.235.1.77 = SK Broadband AS9318 = asn-map 의 cgnat_kr → 미탐 위험이라 해외로 교체.)
VICTIM_SOURCE_IP=222.110.15.50      # KT residential (AS4766) — 집 KT 인터넷
ATTACKER_SOURCE_IP=73.55.20.40      # US Residential — 탈취 토큰 해외 사용 (Impossible Travel)

# S2 — victim 계정 (운영 RDS에서 골라온 실계정 credentials)
#   시뮬이 /auth/login으로 진짜 토큰을 발급받아 사용. forge_token 사용 안 함.
VICTIM_EMAIL=user001@zetty.test
VICTIM_PASSWORD=Victim1234!

# S5 / S5b — 분산 enumeration (쿠팡 패턴 모방)
#   쿠팡 사고: 2,300 IP × 3,367 계정 (IP : 계정 ≈ 0.68 : 1)
#   기본 IP 풀은 VICTIM_COUNT × 0.68 (쿠팡 비율). 0이면 자동 계산.
#   총 호출량은 S4/S5/S5b 모두 VICTIM_COUNT건(각 사용자 1회)으로 통일 — UBA factor 비교용.
S5_IP_POOL_SIZE=0
